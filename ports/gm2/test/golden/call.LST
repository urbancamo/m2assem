  17         0                                    SYMBOL  1
  18         0                                    BASE    D'10
  19         0                            
  20         0                            SUBLOC  EQU     2048                    ; absolute entry of subroutine
  21         0                            BUFLOC  EQU     4096                    ; save-area base
  22         0                            RMASK   EQU     15                      ; mask D0-D3
  23         0                            
  24       400                                    ORG     1024
  25       400                            
  26       400                            Main:
  27       400  6000 0005                         BR      Start                   ; BRA bare-label (Type 11)
  28       402  6100 0003                         CALL    Start                   ; BSR bare-label (Type 11)
  29       404  6139 0000 0800                    CALL    /SUBLOC                 ; JSR absolute   (Type 15)
  30       407                            
  31       407                            Start:
  32       407                                    ;  XCH — EXG (data-reg form) and SWAP (single-operand Type 17).
  33       407                                    ;  Type 24 (XCH) falls through to Type 6, which only accepts
  34       407                                    ;  .B as a modifier, so we have to write XCH.B even though
  35       407                                    ;  the 68000 EXG is actually long-word.
  36       407  C340                              XCH.B   .D0,.D1                 ; EXG
  37       408  C1C2                              XCH.W   .D2                     ; SWAP (single op -> Type 17)
  38       409                            
  39       409                                    ;  ST with register source and memory destination.
  40       409  207C 0000 1000                    LD.L    #BUFLOC,.A0
  41       40C  2083                              ST.L    .D3,@.A0
  42       40D                            
  43       40D                                    ;  STM / LDM with a register mask and indirect EA.
  44       40D  48D0 000F                         STM.L   #RMASK,@.A0             ; MOVEM.L D0-D3,(A0)
  45       40F  4CD0 000F                         LDM.L   #RMASK,@.A0             ; MOVEM.L (A0),D0-D3
  46       411                            
  47       411                                    ;  PUSH / POP — ported Type 26 encodes these as 68000
  48       411                                    ;  MOVE.L Dn,-(SP)  and  MOVE.L (SP)+,Dn respectively, so
  49       411                                    ;  each emits one 16-bit instruction word:
  50       411                                    ;    PUSH .D0  ->  2F00   POP .D0  ->  201F
  51       411                                    ;    PUSH .D7  ->  2F07   POP .D7  ->  2E1F
  52       411  2F00                              PUSH    .D0
  53       412  201F                              POP     .D0
  54       413  2F07                              PUSH    .D7
  55       414  2E1F                              POP     .D7
  56       415                            
  57       415  4E40                              BRK     #0
