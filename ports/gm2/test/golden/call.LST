   1         0                            ;
   2         0                            ;   call.asm -- CALL/RET, STM/LDM, XCH, ST, PUSH/POP, BR
   3         0                            ;
   4         0                            ;   Adds coverage for CALL (via absolute JSR), STM (MOVEM src,ea),
   5         0                            ;   LDM (MOVEM ea,dst), XCH (EXG/SWAP), ST, PUSH and POP.  BR is also
   6         0                            ;   exercised here since it shares Type 25 routing with CALL.
   7         0                            ;
   8         0                            ;   Subroutine addresses are declared via EQU so they land in the
   9         0                            ;   "Absolute" status class and can be referenced through the `/addr`
  10         0                            ;   effective-address form.  Labels placed with "Rel" status can't be
  11         0                            ;   used as CALL/BR targets because Type 25 routes non-immediate
  12         0                            ;   operands to Type 15 (JMP/JSR), whose CalcEA requires an Absolute
  13         0                            ;   type.
  14         0                            ;
  15         0                            
  16         0                                    OBJECT  1
  17         0                                    SYMBOL  1
  18         0                                    BASE    D'10
  19         0                            
  20         0                            SUBLOC  EQU     2048                    ; absolute entry of subroutine
  21         0                            BUFLOC  EQU     4096                    ; save-area base
  22         0                            RMASK   EQU     15                      ; mask D0-D3
  23         0                            
  24       400                                    ORG     1024
  25       400                            
  26       400                            Main:
  27       400  6039 0000 0800                    BR      /SUBLOC                 ; BRA / JMP absolute
  28       403  6139 0000 0800                    CALL    /SUBLOC                 ; BSR / JSR absolute
  29       406                            
  30       406                                    ;  XCH — EXG (data-reg form) and SWAP (single-operand Type 17).
  31       406                                    ;  Type 24 (XCH) falls through to Type 6, which only accepts
  32       406                                    ;  .B as a modifier, so we have to write XCH.B even though
  33       406                                    ;  the 68000 EXG is actually long-word.
  34       406  C340                              XCH.B   .D0,.D1                 ; EXG
  35       407  C1C2                              XCH.W   .D2                     ; SWAP (single op -> Type 17)
  36       408                            
  37       408                                    ;  ST with register source and memory destination.
  38       408  207C 0000 1000                    LD.L    #BUFLOC,.A0
  39       40B  2083                              ST.L    .D3,@.A0
  40       40C                            
  41       40C                                    ;  STM / LDM with a register mask and indirect EA.
  42       40C  48D0 000F                         STM.L   #RMASK,@.A0             ; MOVEM.L D0-D3,(A0)
  43       40E  4CD0 000F                         LDM.L   #RMASK,@.A0             ; MOVEM.L (A0),D0-D3
  44       410                            
  45       410                                    ;  PUSH / POP — Type 26 is a stub in the 1990 code (returns 0
  46       410                                    ;  with no encoding logic), so these just verify that the
  47       410                                    ;  mnemonic is recognised.  No bytes are emitted.
  48       410                                    PUSH    .D0
  49       410                                    POP     .D0
  50       410                            
  51       410  4E40                              BRK     #0
  52       411                            
  53       800                                    ORG     SUBLOC
  54       800  4E75                              RET                             ; RTS
  55       801  4E77                              RETR                            ; RTR  (covered here too)
  56       802  4E73                              RETE                            ; RTE
  57       803                                    END


