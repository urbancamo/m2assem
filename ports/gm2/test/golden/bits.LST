   1         0                            ;
   2         0                            ;   bits.asm -- Type 22 bit-manipulation instructions
   3         0                            ;
   4         0                            ;   Covers the full Type 22 opcode set: TEST1 (BTST), TESTSET (BSET),
   5         0                            ;   TESTCLR (BCLR) and TESTNOT (BCHG).
   6         0                            ;
   7         0                            ;   TEST1 is the only mnemonic in the entire opcode table that contains
   8         0                            ;   a digit.  The original 1990 Lex.ExtractCommand read only alphabetic
   9         0                            ;   characters for a command name, so TEST1 couldn't be parsed at all
  10         0                            ;   — it sat in the opcode table unreachable for 35 years.  The lexer
  11         0                            ;   was extended during the gm2 port to also accept trailing digits
  12         0                            ;   (letters first, then letters-or-digits), which matches the usual
  13         0                            ;   identifier rule and unblocks TEST1 without opening up anything
  14         0                            ;   unintended.  Any fixture built from this file is therefore a
  15         0                            ;   regression test for that lexer fix too.
  16         0                            ;
  17         0                            
  18         0                                    OBJECT  1
  19         0                                    SYMBOL  1
  20         0                                    BASE    D'10
  21         0                            
  22       400                                    ORG     1024
  23       400                            
  24       400  203C 0000 0005                    LD.L    #5,.D0                  ; bit number
  25       403  223C 0000 0000                    LD.L    #0,.D1                  ; target word
  26       406                            
  27       406  0300                              TEST1   .D0,.D1                 ; BTST — test bit
  28       407  03C0                              TESTSET .D0,.D1                 ; BSET — test and set
  29       408  0380                              TESTCLR .D0,.D1                 ; BCLR — test and clear
  30       409  0340                              TESTNOT .D0,.D1                 ; BCHG — test and change
  31       40A                            
  32       40A  4E40                              BRK     #0
  33       40B                            
