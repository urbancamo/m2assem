  58       403                            
  59       403                                    ;  AutoPostInc — .An+   ->  68000 (An)+
  60       403  2018                              MOV.L   .A0+,.D0
  61       404                            
  62       404                                    ;  AutoPreDec  — -.An   ->  68000 -(An)
  63       404  2220                              MOV.L   -.A0,.D1
  64       405                            
  65       405                                    ;  Index       — @.An(.Xn,d8)  ->  68000 d8(An,Xn.W)
  66       405                                    ;  IEEE order is (index_reg,disp) — register first, then displacement.
  67       405  2430 6804                         MOV.L   @.A0(.D6,4),.D2
  68       407                            
  69       407                                    ;  Rel         — $label  ->  #imm with a Relative-typed value
  70       407                                    ;  (The 1990 code lets you use a label's address as an
  71       407                                    ;  immediate without tripping the "Argument must be absolute"
  72       407                                    ;  check.)
  73       407  263C 0000 1000                    MOV.L   $ARRLOC,.D3
  74       40A                            
  75       40A  4E40                              BRK     #0
